# ── Backend (server/) ───────────────────────────────────────────────
# Ключ DeepSeek живёт ТОЛЬКО на сервере и никогда не попадает в бандл фронта.
DEEPSEEK_API_KEY=
# Необязательно: переопределить эндпоинт/модель DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Порт бэкенд-прокси (внутри Docker; снаружи — Caddy на 80/443)
PORT=8787
NODE_ENV=production

# ── Frontend (Vite, подставляется на этапе docker build) ────────────
# true  → ДЕМО-режим по умолчанию (офлайн, «золотые» данные из src/mock)
# false → LIVE-режим по умолчанию (реальный анализ через POST /api/analyze)
# Режим можно переключать тумблером в шапке в любой момент.
VITE_DEMO_MODE=false
